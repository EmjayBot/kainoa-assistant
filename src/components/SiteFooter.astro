---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-white/[0.06] bg-[#05070a]">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col lg:flex-row items-start justify-between gap-10">
      <div class="flex items-start gap-4">
       <div class="w-10 h-10 rounded-[10px] bg-gradient-to-br from-[#38bdf8] to-[#2563eb] flex items-center justify-center shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]">
  <span class="font-semibold text-[18px] text-white leading-none">K</span>
</div>
        <div>
          <h2 class="text- font-semibold text-white tracking-tight">Kainoa</h2>
          <p class="text- text-slate-400 mt-1 max-w- leading-snug">
            The citizenship and lore assistant for the TEP Worlds community.
            Instant answers, forum search, and web search in one place.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-">
        <div>
          <h3 class="text- font-semibold uppercase tracking-wider text-slate-500 mb-3">The East Pacific</h3>
          <ul class="space-y-2 text-slate-400">
            <li><a href="https://forum.theeastpacific.com" target="_blank" class="hover:text-cyan-400 transition">Forum</a></li>
            <li><a href="https://www.nationstates.net/region=the_east_pacific" target="_blank" class="hover:text-cyan-400 transition">Region Page</a></li>
            <li><a href="https://discord.gg/theeastpacific" target="_blank" class="hover:text-cyan-400 transition">Discord</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text- font-semibold uppercase tracking-wider text-slate-500 mb-3">Urth</h3>
          <ul class="space-y-2 text-slate-400">
            <li><a href="https://forum.theeastpacific.com/c/urth" target="_blank" class="hover:text-cyan-400 transition">Urth Forum</a></li>
            <li><a href="https://wiki.theeastpacific.com/urth" target="_blank" class="hover:text-cyan-400 transition">Urth Wiki</a></li>
            <li><a href="https://discord.gg/urth" target="_blank" class="hover:text-cyan-400 transition">Urth Discord</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text- font-semibold uppercase tracking-wider text-slate-500 mb-3">Valsora</h3>
          <ul class="space-y-2 text-slate-400">
            <li><a href="https://forum.theeastpacific.com/c/valsora" target="_blank" class="hover:text-cyan-400 transition">Valsora Forum</a></li>
            <li><a href="https://wiki.theeastpacific.com/valsora" target="_blank" class="hover:text-cyan-400 transition">Valsora Wiki</a></li>
            <li><a href="https://discord.gg/valsora" target="_blank" class="hover:text-cyan-400 transition">Community Hub</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/[0.04] bg-black/20">
    <div class="mx-auto max-w-6xl px-6 py-3 flex flex-col sm:flex-row items-center justify-between gap-2 text- text-slate-600">
      <div class="flex items-center gap-3">
        <span>© {year} TEP Worlds Community</span>
        <span class="hidden sm:inline">•</span>
        <span>Not affiliated with NationStates</span>
      </div>
      <div class="flex items-center gap-3">
        <span>Powered by</span>
        <span class="text-slate-500">Astro</span>
        <span class="text-slate-700">•</span>
        <span class="text-slate-500">React</span>
        <span class="text-slate-700">•</span>
        <span class="text-slate-500">Tailwind</span>
        <span class="text-slate-700">•</span>
        <span class="text-slate-500">GitHub Pages</span>
        <span class="text-slate-700">•</span>
        <a href="https://github.com/ricky-who/kainoa" target="_blank" class="hover:text-slate-400 transition">Source</a>
      </div>
    </div>
  </div>
</footer>
