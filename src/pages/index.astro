---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import KainoaChat from '../components/KainoaChat.jsx';
---

<StarlightPage frontmatter={{ title: 'Kainoa Assistant', template: 'splash' }}>
  <div class="mx-auto w-full max-w-3xl px-4 py-4">
    <KainoaChat client:load />
  </div>
</StarlightPage>

<style is:global>
  /* Hide the big duplicate title since Starlight nav already shows it */
  .sl-container > h1 { display: none; }
</style>