---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import KainoaChat from '../components/KainoaChat.jsx';
---

<StarlightPage frontmatter={{ title: 'Kainoa Assistant', description: 'TEP Kainoa' }}>
  <KainoaChat client:load />
  
  <footer class="mt-12 border-t border-slate-800 pt-6 pb-12 text-center text-xs text-slate-500">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
      <span>© 2026 EmjayBot • Kainoa Assistant</span>
      <span class="hidden sm:inline">•</span>
      <a href="https://forum.theeastpacific.com" class="hover:text-cyan-400 transition">Forum</a>
      <span>•</span>
      <a href="https://github.com/EmjayBot/kainoa-assistant" class="hover:text-cyan-400 transition">GitHub</a>
    </div>
    <div class="mt-2">Built with Astro + Starlight • Runs locally in your browser</div>
  </footer>
</StarlightPage>
