---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Forum Search' }}>
  <div class="max-w-3xl mx-auto">
    <div class="flex gap-2 mb-4">
      <input id="q" type="text" placeholder="citizenship, magisterium..."
        class="flex-1 h-12 px-4 rounded-xl bg-[#0f172a] border-2 border-slate-700 text-white focus:border-sky-500 outline-none" 
        autocomplete="off" autofocus />
      <button id="go" class="h-12 px-6 bg-sky-600 rounded-xl text-white font-bold">Search</button>
    </div>
    <div id="out" class="space-y-3"></div>
  </div>
</StarlightPage>

<script is:inline>
  const FORUM = 'https://forum.theeastpacific.com';
  const q = document.getElementById('q');
  const go = document.getElementById('go');
  const out = document.getElementById('out');

  async function search() {
    const term = q.value.trim();
    if (!term) return;
    out.innerHTML = '<div class="text-slate-500">Searching...</div>';
    
    try {
      // DIRECT fetch — no proxy, CORS is whitelisted
      const res = await fetch(`${FORUM}/search.json?q=${encodeURIComponent(term)}`, {
        method: 'GET',
        credentials: 'omit',
        headers: { 'Accept': 'application/json' }
      });
      
      if (!res.ok) throw new Error(res.status);
      const data = await res.json();
      const topics = data.topics || [];

      if (!topics.length) {
        out.innerHTML = `<div class="text-amber-400">No results for "${term}"</div>`;
        return;
      }

      out.innerHTML = topics.slice(0,10).map(t => `
        <a href="${FORUM}/t/${t.slug}/${t.id}" target="_blank"
           class="block p-4 rounded-xl bg-[#11151f] border border-slate-800 hover:border-sky-600">
          <div class="text-white font-medium">${t.title}</div>
          <div class="text-xs text-slate-400 mt-1">${(t.excerpt||'').replace(/<[^>]*>/g,'')}</div>
        </a>
      `).join('');
    } catch (e) {
      out.innerHTML = `<div class="text-red-400">Direct fetch failed: ${e.message}. Check Discourse CORS settings for your Pages domain.</div>`;
      console.error(e);
    }
  }

  go.onclick = search;
  q.onkeydown = e => e.key === 'Enter' && search();
</script>
