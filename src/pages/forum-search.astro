---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Forum Search', description: 'Search forum.theeastpacific.com' }}>
  <div class="max-w-3xl mx-auto">
    <div class="flex gap-2 mb-4">
      <input id="q" placeholder="Search citizenship, magisterium..." class="flex-1 h-11 rounded-xl bg-[#11151f] border border-slate-700 px-4 text-white outline-none" />
      <button id="go" class="h-11 px-5 rounded-xl bg-sky-600 text-white font-bold">Search</button>
    </div>
    <div id="out" class="space-y-3 text-slate-300">Type a term above.</div>
  </div>

  <script>
    const FORUM = 'https://forum.theeastpacific.com';
    const out = document.getElementById('out');
    const q = document.getElementById('q');
    const go = document.getElementById('go');

    async function search(term) {
      if (!term) return;
      out.innerHTML = '<div class="text-slate-500">Searching...</div>';
      
      const urls = [
        `https://r.jina.ai/http://forum.theeastpacific.com/search.json?q=${encodeURIComponent(term)}`,
        `https://api.allorigins.win/get?url=${encodeURIComponent(FORUM + '/search.json?q=' + encodeURIComponent(term))}`
      ];

      for (const url of urls) {
        try {
          const r = await fetch(url, { cache: 'no-store' });
          let txt = await r.text();
          let data = JSON.parse(txt);
          if (data.contents) data = JSON.parse(data.contents);
          
          const topics = data.topics || [];
          if (topics.length) {
            out.innerHTML = topics.slice(0,10).map(t => `
              <a href="${FORUM}/t/${t.slug}/${t.id}" target="_blank" class="block p-4 rounded-xl bg-[#11151f] border border-slate-800 hover:border-sky-700">
                <div class="text-white font-medium">${t.title}</div>
                <div class="text-xs text-slate-400 mt-1">${(t.excerpt||'').replace(/<[^>]*>/g,'')}</div>
              </a>
            `).join('');
            return;
          }
        } catch(e) { continue; }
      }
      out.innerHTML = '<div class="text-amber-400">No results — try "citizenship" or "Magisterium"</div>';
    }

    go.onclick = () => search(q.value);
    q.onkeydown = e => e.key === 'Enter' && search(q.value);
    
    // auto-search if ?q= in URL
    const params = new URLSearchParams(location.search);
    if (params.get('q')) { q.value = params.get('q'); search(q.value); }
  </script>
</StarlightPage>