---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Forum Search', description: 'Search The East Pacific forum directly' }}>
  <div class="not-content max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-white mb-2">Forum Search</h1>
    <p class="text-zinc-400 mb-6">Live search of forum.theeastpacific.com</p>

    <div class="relative mb-6">
      <input
        id="forum-q"
        type="text"
        placeholder="Search forum.theeastpacific.com..."
        class="w-full px-5 py-4 bg-zinc-900 border border-zinc-800 rounded-2xl text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-violet-500"
      />
    </div>

    <div id="forum-results" class="space-y-3">
      <div class="text-zinc-500 text-sm">Loading latest topics...</div>
    </div>
  </div>

  <script>
    const FORUM = 'https://forum.theeastpacific.com';
    const PROXY = 'https://api.allorigins.win/raw?url=';
    const build = (p) => `${PROXY}${encodeURIComponent(FORUM + p)}`;

    const $q = document.getElementById('forum-q');
    const $r = document.getElementById('forum-results');

    async function fetchJSON(path) {
      const res = await fetch(build(path));
      return res.json();
    }

    function render(topics) {
      $r.innerHTML = topics.map(t => `
        <a href="${FORUM}/t/${t.slug}/${t.id}" target="_blank"
           class="block p-4 bg-zinc-900/70 border border-zinc-800 rounded-xl hover:bg-zinc-900">
          <div class="text-white font-medium">${t.title}</div>
          <div class="text-zinc-400 text-sm mt-1">${(t.excerpt||'').replace(/<[^>]*>/g,'')}</div>
          <div class="text-zinc-600 text-xs mt-2">${t.posts_count||0} replies</div>
        </a>
      `).join('') || '<div class="text-zinc-500">No results</div>';
    }

    async function latest() {
      const data = await fetchJSON('/latest.json');
      render(data.topic_list.topics.slice(0,12));
    }

    async function search(q) {
      if (!q.trim()) return latest();
      const data = await fetchJSON(`/search.json?q=${encodeURIComponent(q)}`);
      render((data.topics||[]).slice(0,10));
    }

    let timer;
    $q.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => search($q.value), 300);
    });

    latest();
  </script>
</StarlightPage>

<style>
  .not-content { max-width: none; }
</style>